{
  "datasets": [
    {
      "name": "b96f1ce7",
      "displayName": "fraud_features",
      "queryLines": [
        "SELECT * FROM workspace.default.fraud_features"
      ]
    },
    {
      "name": "fdcb5097",
      "displayName": "1. Métricas principais",
      "queryLines": [
        "SELECT \r\n",
        "    COUNT(*) as total_transacoes,\r\n",
        "    SUM(CASE WHEN is_fraud = 1 THEN 1 ELSE 0 END) as fraudes_reais,\r\n",
        "    SUM(CASE WHEN prediction = 1 THEN 1 ELSE 0 END) as fraudes_detectadas,\r\n",
        "    ROUND(AVG(CASE WHEN is_fraud = 1 THEN 1 ELSE 0 END) * 100, 2) as taxa_fraude_real,\r\n",
        "    ROUND(SUM(CASE WHEN is_fraud = 1 AND prediction = 1 THEN 1 ELSE 0 END) * 100.0 / NULLIF(SUM(is_fraud), 0), 2) as taxa_deteccao\r\n",
        "FROM fraud_predictions_final"
      ]
    },
    {
      "name": "7d86f86a",
      "displayName": "2. Matriz de Confusão",
      "queryLines": [
        "SELECT \r\n",
        "    CASE WHEN is_fraud = 0 THEN 'Legítima' ELSE 'Fraude' END as real,\r\n",
        "    CASE WHEN prediction = 0 THEN 'Legítima' ELSE 'Fraude' END as predicao,\r\n",
        "    COUNT(*) as quantidade\r\n",
        "FROM fraud_predictions_final\r\n",
        "GROUP BY is_fraud, prediction\r\n",
        "ORDER BY is_fraud DESC, prediction DESC"
      ]
    },
    {
      "name": "62306d26",
      "displayName": "3. Fraudes por Categoria",
      "queryLines": [
        "SELECT \r\n",
        "    merchant_category,\r\n",
        "    COUNT(*) as total_transacoes,\r\n",
        "    SUM(is_fraud) as fraudes,\r\n",
        "    ROUND(AVG(is_fraud) * 100, 2) as taxa_fraude\r\n",
        "FROM fraud_predictions_final\r\n",
        "GROUP BY merchant_category\r\n",
        "ORDER BY taxa_fraude DESC"
      ]
    },
    {
      "name": "206ed38e",
      "displayName": "4. Fraudes por Hora do Dia",
      "queryLines": [
        "SELECT \r\n",
        "    transaction_hour as hora,\r\n",
        "    COUNT(*) as transacoes,\r\n",
        "    SUM(is_fraud) as fraudes,\r\n",
        "    ROUND(AVG(is_fraud) * 100, 2) as taxa_fraude\r\n",
        "FROM fraud_predictions_final\r\n",
        "GROUP BY transaction_hour\r\n",
        "ORDER BY transaction_hour"
      ]
    },
    {
      "name": "9cc69593",
      "displayName": "5. Distribuição de Valores",
      "queryLines": [
        "SELECT \r\n",
        "    CASE \r\n",
        "        WHEN amount < 100 THEN '0-100'\r\n",
        "        WHEN amount < 500 THEN '100-500'\r\n",
        "        WHEN amount < 1000 THEN '500-1000'\r\n",
        "        ELSE '1000+'\r\n",
        "    END as faixa_valor,\r\n",
        "    COUNT(*) as transacoes,\r\n",
        "    SUM(is_fraud) as fraudes\r\n",
        "FROM fraud_predictions_final\r\n",
        "GROUP BY \r\n",
        "    CASE \r\n",
        "        WHEN amount < 100 THEN '0-100'\r\n",
        "        WHEN amount < 500 THEN '100-500'\r\n",
        "        WHEN amount < 1000 THEN '500-1000'\r\n",
        "        ELSE '1000+'\r\n",
        "    END\r\n",
        "ORDER BY faixa_valor"
      ]
    },
    {
      "name": "e20282da",
      "displayName": "6. Transações Estrangeiras",
      "queryLines": [
        "SELECT \r\n",
        "    CASE WHEN foreign_transaction = 1 THEN 'Internacional' ELSE 'Nacional' END as tipo,\r\n",
        "    COUNT(*) as quantidade,\r\n",
        "    SUM(is_fraud) as fraudes,\r\n",
        "    ROUND(AVG(is_fraud) * 100, 2) as taxa_fraude\r\n",
        "FROM fraud_predictions_final\r\n",
        "GROUP BY foreign_transaction"
      ]
    },
    {
      "name": "ff8878b5",
      "displayName": "7. Performance do Modelo",
      "queryLines": [
        "SELECT \r\n",
        "    'True Positives' as metrica,\r\n",
        "    SUM(CASE WHEN is_fraud = 1 AND prediction = 1 THEN 1 ELSE 0 END) as valor\r\n",
        "FROM fraud_predictions_final\r\n",
        "UNION ALL\r\n",
        "SELECT 'True Negatives', SUM(CASE WHEN is_fraud = 0 AND prediction = 0 THEN 1 ELSE 0 END)\r\n",
        "FROM fraud_predictions_final\r\n",
        "UNION ALL\r\n",
        "SELECT 'False Positives', SUM(CASE WHEN is_fraud = 0 AND prediction = 1 THEN 1 ELSE 0 END)\r\n",
        "FROM fraud_predictions_final\r\n",
        "UNION ALL\r\n",
        "SELECT 'False Negatives', SUM(CASE WHEN is_fraud = 1 AND prediction = 0 THEN 1 ELSE 0 END)\r\n",
        "FROM fraud_predictions_final"
      ]
    },
    {
      "name": "e3b5a196",
      "displayName": "8. Score de Confiança do Dispositivo",
      "queryLines": [
        "SELECT \r\n",
        "    CASE WHEN is_fraud = 1 THEN 'Fraude' ELSE 'Legítima' END as tipo,\r\n",
        "    device_trust_score\r\n",
        "FROM fraud_predictions_final"
      ]
    },
    {
      "name": "9584bb8a",
      "displayName": "9. Top 10 Transações Suspeitas",
      "queryLines": [
        "SELECT \r\n",
        "    transaction_id,\r\n",
        "    amount,\r\n",
        "    merchant_category,\r\n",
        "    foreign_transaction,\r\n",
        "    device_trust_score,\r\n",
        "    is_fraud,\r\n",
        "    prediction,\r\n",
        "    probability\r\n",
        "FROM fraud_predictions_final\r\n",
        "WHERE prediction = 1\r\n",
        "ORDER BY amount DESC\r\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "12f60376",
      "displayName": "10. Evolução Temporal",
      "queryLines": [
        "SELECT \r\n",
        "    transaction_hour,\r\n",
        "    COUNT(*) as transacoes,\r\n",
        "    SUM(prediction) as alertas_fraude\r\n",
        "FROM fraud_predictions_final\r\n",
        "GROUP BY transaction_hour\r\n",
        "ORDER BY transaction_hour"
      ]
    }
  ],
